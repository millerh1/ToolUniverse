        "enzymes": "SRC",
        "limit": 20
      },
      {
        "enzymes": "LCK",
        "substrates": "SOCS3"
      },
      {
        "enzymes": "EGFR",
        "types": "phosphorylation",
        "limit": 15
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
