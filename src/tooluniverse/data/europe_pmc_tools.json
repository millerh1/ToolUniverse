[
  {
    "type": "EuropePMCTool",
    "name": "EuropePMC_search_articles",
    "description": "Search for articles on Europe PMC including abstracts. The tool queries the Europe PMC web service using provided keywords and returns articles with details such as title, abstract, journal, publication year, and a URL to the full article.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query for Europe PMC. Use keywords separated by spaces to refine your search."
        },
        "limit": {
          "type": "integer",
          "description": "Number of articles to return. This sets the maximum number of articles retrieved from Europe PMC.",
          "default": 5
        },
        "enrich_missing_abstract": {
          "type": "boolean",
          "description": "If true, best-effort fills missing abstracts by fetching Europe PMC fullTextXML (bounded to a few results).",
          "default": false
        },
        "extract_terms_from_fulltext": {
          "type": "array",
          "description": "Optional list of terms to extract from full text (open access only). When provided, automatically fetches fullTextXML for open-access articles and returns snippets around these terms. Max 5 terms, bounded to first 3 OA articles to avoid latency. Returns snippets in a 'fulltext_snippets' field for each article.",
          "items": {
            "type": "string"
          },
          "maxItems": 5
        }
      },
      "required": [
        "query"
      ]
    },
    "return_schema": {
      "type": "array",
      "description": "List of articles from Europe PMC matching the search query",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Title of the article"
          },
          "abstract": {
            "type": [
              "string",
              "null"
            ],
            "description": "Abstract of the article"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of author names"
          },
          "journal": {
            "type": [
              "string",
              "null"
            ],
            "description": "Journal name where the article was published"
          },
          "year": {
            "type": [
              "integer",
              "string",
              "null"
            ],
            "description": "Publication year"
          },
          "doi": {
            "type": [
              "string",
              "null"
            ],
            "description": "Digital Object Identifier"
          },
          "doi_url": {
            "type": [
              "string",
              "null"
            ],
            "description": "DOI resolver URL"
          },
          "url": {
            "type": [
              "string",
              "null"
            ],
            "description": "URL to the article on Europe PMC"
          },
          "pmid": {
            "type": [
              "string",
              "null"
            ],
            "description": "PubMed ID (when available)"
          },
          "pmcid": {
            "type": [
              "string",
              "null"
            ],
            "description": "PubMed Central ID (when available)"
          },
          "fulltext_xml_url": {
            "type": [
              "string",
              "null"
            ],
            "description": "Europe PMC fullTextXML URL (when derivable)"
          },
          "abstract_source": {
            "type": [
              "string",
              "null"
            ],
            "description": "Source of abstract text (e.g., Europe PMC core or fullTextXML)"
          },
          "fulltext_snippets": {
            "type": "array",
            "description": "Full-text snippets around search terms (only present when extract_terms_from_fulltext is provided and article is OA)",
            "items": {
              "type": "object",
              "properties": {
                "term": {
                  "type": "string",
                  "description": "The search term that was matched"
                },
                "snippet": {
                  "type": "string",
                  "description": "Text snippet with context around the matched term"
                }
              }
            }
          },
          "fulltext_snippets_count": {
            "type": "integer",
            "description": "Number of snippets extracted (only present when fulltext_snippets exists)"
          },
          "citations": {
            "type": "integer",
            "description": "Number of citations"
          },
          "open_access": {
            "type": "boolean",
            "description": "Open access status"
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of keywords"
          },
          "source": {
            "type": "string",
            "description": "Source identifier (always 'Europe PMC')"
          },
          "data_quality": {
            "type": "object",
            "description": "Data quality indicators",
            "properties": {
              "has_abstract": {
                "type": "boolean"
              },
              "has_authors": {
                "type": "boolean"
              },
              "has_journal": {
                "type": "boolean"
              },
              "has_year": {
                "type": "boolean"
              },
              "has_doi": {
                "type": "boolean"
              },
              "has_citations": {
                "type": "boolean"
              },
              "has_keywords": {
                "type": "boolean"
              },
              "has_url": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "query": "cancer therapy",
        "limit": 5
      }
    ]
  },
  {
    "type": "EuropePMCRESTTool",
    "name": "EuropePMC_get_citations",
    "description": "Get citations for an article from Europe PMC. Citations are articles that cite the specified article. Requires a source (e.g., 'MED' for PubMed, 'PMC' for PMC) and article ID. Use EuropePMC_search_articles to find article IDs first.",
    "parameter": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "description": "Source database (e.g., 'MED' for PubMed, 'PMC' for PMC). Usually 'MED' for most articles.",
          "default": "MED"
        },
        "article_id": {
          "type": "string",
          "description": "Article ID from the source database (e.g., PMID for MED source)"
        },
        "page_size": {
          "type": "integer",
          "description": "Number of citations to retrieve (default: 25, max: 1000)",
          "default": 25,
          "minimum": 1,
          "maximum": 1000
        },
        "page": {
          "type": "integer",
          "description": "Page number for pagination (default: 1)",
          "default": 1,
          "minimum": 1
        }
      },
      "required": [
        "article_id"
      ]
    },
    "fields": {
      "endpoint": "https://www.ebi.ac.uk/europepmc/webservices/rest/{source}/{article_id}/citations"
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "data": {
          "type": "object",
          "properties": {
            "version": {
              "type": "string"
            },
            "hitCount": {
              "type": "integer"
            },
            "citationList": {
              "type": "object",
              "properties": {
                "citation": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "source": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      },
                      "authorString": {
                        "type": "string"
                      },
                      "journalAbbreviation": {
                        "type": "string"
                      },
                      "pubYear": {
                        "type": [
                          "integer",
                          "string"
                        ]
                      },
                      "citedOrder": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "url": {
          "type": "string"
        },
        "error": {
          "type": "string"
        },
        "status_code": {
          "type": "integer"
        }
      }
    },
    "test_examples": [
      {
        "source": "MED",
        "article_id": "25428363",
        "page_size": 10
      }
    ]
  },
  {
    "type": "EuropePMCRESTTool",
    "name": "EuropePMC_get_references",
    "description": "Get references (bibliography) for an article from Europe PMC. References are articles cited by the specified article. Requires a source (e.g., 'MED' for PubMed, 'PMC' for PMC) and article ID. Use EuropePMC_search_articles to find article IDs first.",
    "parameter": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "description": "Source database (e.g., 'MED' for PubMed, 'PMC' for PMC). Usually 'MED' for most articles.",
          "default": "MED"
        },
        "article_id": {
          "type": "string",
          "description": "Article ID from the source database (e.g., PMID for MED source)"
        },
        "page_size": {
          "type": "integer",
          "description": "Number of references to retrieve (default: 25, max: 1000)",
          "default": 25,
          "minimum": 1,
          "maximum": 1000
        },
        "page": {
          "type": "integer",
          "description": "Page number for pagination (default: 1)",
          "default": 1,
          "minimum": 1
        }
      },
      "required": [
        "article_id"
      ]
    },
    "fields": {
      "endpoint": "https://www.ebi.ac.uk/europepmc/webservices/rest/{source}/{article_id}/references"
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "data": {
          "type": "object",
          "properties": {
            "version": {
              "type": "string"
            },
            "hitCount": {
              "type": "integer"
            },
            "referenceList": {
              "type": "object",
              "properties": {
                "reference": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "source": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      },
                      "authorString": {
                        "type": "string"
                      },
                      "journalAbbreviation": {
                        "type": "string"
                      },
                      "pubYear": {
                        "type": [
                          "integer",
                          "string"
                        ]
                      },
                      "citedOrder": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "url": {
          "type": "string"
        },
        "error": {
          "type": "string"
        },
        "status_code": {
          "type": "integer"
        }
      }
    },
    "test_examples": [
      {
        "source": "MED",
        "article_id": "25428363",
        "page_size": 10
      }
    ]
  }
  ,
  {
    "type": "EuropePMCFullTextSnippetsTool",
    "name": "EuropePMC_get_fulltext_snippets",
    "description": "Fetch an article's Europe PMC fullTextXML (open access) and return bounded text snippets around provided terms. Use this when a key detail is likely in the full text (methods, figure captions, section titles) rather than the abstract.",
    "parameter": {
      "type": "object",
      "properties": {
        "fulltext_xml_url": {
          "type": "string",
          "description": "Direct Europe PMC fullTextXML URL (recommended when you already have it from EuropePMC_search_articles)."
        },
        "pmcid": {
          "type": "string",
          "description": "PMC ID (e.g., 'PMC11237425' or '11237425'). If provided, the tool derives the Europe PMC fullTextXML URL."
        },
        "source_db": {
          "type": "string",
          "description": "Europe PMC source database (e.g., 'MED' or 'PMC'). Used with `article_id` to derive the fullTextXML URL."
        },
        "article_id": {
          "type": "string",
          "description": "Europe PMC article ID within `source_db` (e.g., PMID for source_db='MED')."
        },
        "terms": {
          "type": "array",
          "description": "Terms to search for in the extracted full text (case-insensitive).",
          "items": {
            "type": "string"
          }
        },
        "window_chars": {
          "type": "integer",
          "description": "Context window size (characters) before and after each match.",
          "default": 220,
          "minimum": 20,
          "maximum": 2000
        },
        "max_snippets_per_term": {
          "type": "integer",
          "description": "Maximum number of snippets returned per term.",
          "default": 3,
          "minimum": 1,
          "maximum": 10
        },
        "max_total_chars": {
          "type": "integer",
          "description": "Hard cap on total characters returned across all snippets.",
          "default": 8000,
          "minimum": 1000,
          "maximum": 50000
        }
      },
      "required": [
        "terms"
      ]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "url": {
          "type": "string"
        },
        "snippets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "term": {
                "type": "string"
              },
              "snippet": {
                "type": "string"
              }
            }
          }
        },
        "snippets_count": {
          "type": "integer"
        },
        "truncated": {
          "type": "boolean"
        },
        "error": {
          "type": "string"
        },
        "status_code": {
          "type": "integer"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "test_examples": [
      {
        "pmcid": "PMC11237425",
        "terms": [
          "ciprofloxacin",
          "evolved resistance"
        ]
      }
    ]
  }
]
