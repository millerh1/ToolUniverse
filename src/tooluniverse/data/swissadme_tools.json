[
  {
    "name": "SwissADME_calculate_adme",
    "type": "SwissADMETool",
    "description": "Compute ADMET properties, drug-likeness, and medicinal chemistry friendliness of a small molecule from its SMILES string using SwissADME. Returns 49 properties across 6 categories: physicochemical properties (MW, TPSA, rotatable bonds, H-bond donors/acceptors), lipophilicity (iLOGP, XLOGP3, WLOGP, MLOGP, consensus LogP), water solubility (ESOL, Ali, Silicos-IT with log S, mg/ml, mol/l, and class), pharmacokinetics (GI absorption, BBB permeation, Pgp substrate, CYP1A2/2C19/2C9/2D6/3A4 inhibition, skin permeation), drug-likeness (Lipinski, Ghose, Veber, Egan, Muegge rule violations, bioavailability score), and medicinal chemistry (PAINS alerts, Brenk alerts, leadlikeness, synthetic accessibility). Computation takes 5-15 seconds.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "enum": ["calculate_adme"],
          "description": "Operation type"
        },
        "smiles": {
          "type": "string",
          "description": "SMILES string of the molecule to analyze. Must be a valid small molecule SMILES. Examples: CC(=O)Oc1ccccc1C(=O)O (aspirin), CC(C)Cc1ccc(cc1)C(C)C(=O)O (ibuprofen), c1ccc2[nH]c(-c3ccncc3)cc2c1 (omeprazole core)"
        },
        "molecule_name": {
          "type": ["string", "null"],
          "description": "Optional name for the molecule. If not provided, SwissADME assigns 'Molecule 1'."
        }
      },
      "required": ["operation", "smiles"]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "molecule_name": {"type": ["string", "null"], "description": "Name of the molecule"},
        "canonical_smiles": {"type": ["string", "null"], "description": "Canonical SMILES generated by SwissADME"},
        "physicochemical": {
          "type": "object",
          "description": "Physicochemical properties",
          "properties": {
            "formula": {"type": ["string", "null"]},
            "molecular_weight": {"type": ["number", "null"], "description": "Molecular weight in g/mol"},
            "num_heavy_atoms": {"type": ["integer", "null"]},
            "num_aromatic_heavy_atoms": {"type": ["integer", "null"]},
            "fraction_csp3": {"type": ["number", "null"]},
            "num_rotatable_bonds": {"type": ["integer", "null"]},
            "num_hbond_acceptors": {"type": ["integer", "null"]},
            "num_hbond_donors": {"type": ["integer", "null"]},
            "molar_refractivity": {"type": ["number", "null"]},
            "tpsa": {"type": ["number", "null"], "description": "Topological Polar Surface Area in A^2"}
          }
        },
        "lipophilicity": {
          "type": "object",
          "description": "Lipophilicity predictions from multiple methods",
          "properties": {
            "ilogp": {"type": ["number", "null"]},
            "xlogp3": {"type": ["number", "null"]},
            "wlogp": {"type": ["number", "null"]},
            "mlogp": {"type": ["number", "null"]},
            "silicosit_logp": {"type": ["number", "null"]},
            "consensus_logp": {"type": ["number", "null"], "description": "Consensus Log Po/w (average of all methods)"}
          }
        },
        "water_solubility": {
          "type": "object",
          "description": "Water solubility predictions (ESOL, Ali, Silicos-IT)",
          "properties": {
            "esol_logs": {"type": ["number", "null"]},
            "esol_solubility_mg_ml": {"type": ["number", "null"]},
            "esol_solubility_mol_l": {"type": ["number", "null"]},
            "esol_class": {"type": ["string", "null"], "description": "ESOL class: Insoluble/Poorly soluble/Moderately soluble/Soluble/Very soluble/Highly soluble"},
            "ali_logs": {"type": ["number", "null"]},
            "ali_solubility_mg_ml": {"type": ["number", "null"]},
            "ali_solubility_mol_l": {"type": ["number", "null"]},
            "ali_class": {"type": ["string", "null"]},
            "silicosit_logsw": {"type": ["number", "null"]},
            "silicosit_solubility_mg_ml": {"type": ["number", "null"]},
            "silicosit_solubility_mol_l": {"type": ["number", "null"]},
            "silicosit_class": {"type": ["string", "null"]}
          }
        },
        "pharmacokinetics": {
          "type": "object",
          "description": "Pharmacokinetic properties",
          "properties": {
            "gi_absorption": {"type": ["string", "null"], "description": "GI absorption: High or Low"},
            "bbb_permeant": {"type": ["string", "null"], "description": "BBB permeant: Yes or No"},
            "pgp_substrate": {"type": ["string", "null"], "description": "P-glycoprotein substrate: Yes or No"},
            "cyp1a2_inhibitor": {"type": ["string", "null"]},
            "cyp2c19_inhibitor": {"type": ["string", "null"]},
            "cyp2c9_inhibitor": {"type": ["string", "null"]},
            "cyp2d6_inhibitor": {"type": ["string", "null"]},
            "cyp3a4_inhibitor": {"type": ["string", "null"]},
            "log_kp": {"type": ["number", "null"], "description": "Skin permeation log Kp in cm/s"}
          }
        },
        "druglikeness": {
          "type": "object",
          "description": "Drug-likeness rule violations (0 = passes rule)",
          "properties": {
            "lipinski_violations": {"type": ["integer", "null"], "description": "Lipinski Rule of Five violations (0 = drug-like)"},
            "ghose_violations": {"type": ["integer", "null"]},
            "veber_violations": {"type": ["integer", "null"]},
            "egan_violations": {"type": ["integer", "null"]},
            "muegge_violations": {"type": ["integer", "null"]},
            "bioavailability_score": {"type": ["number", "null"], "description": "Oral bioavailability score (0-1)"}
          }
        },
        "medicinal_chemistry": {
          "type": "object",
          "description": "Medicinal chemistry alerts and scores",
          "properties": {
            "pains_alerts": {"type": ["integer", "null"], "description": "PAINS (Pan Assay Interference) alerts count"},
            "brenk_alerts": {"type": ["integer", "null"], "description": "Brenk structural alert count"},
            "leadlikeness_violations": {"type": ["integer", "null"]},
            "synthetic_accessibility": {"type": ["number", "null"], "description": "SA score from 1 (easy) to 10 (difficult)"}
          }
        }
      }
    },
    "test_examples": [
      {
        "operation": "calculate_adme",
        "smiles": "CC(=O)Oc1ccccc1C(=O)O",
        "molecule_name": "aspirin"
      }
    ]
  },
  {
    "name": "SwissADME_check_druglikeness",
    "type": "SwissADMETool",
    "description": "Quick drug-likeness assessment of a small molecule using SwissADME. Evaluates the molecule against five standard drug-likeness filters: Lipinski Rule of Five (MW, LogP, HBD, HBA), Ghose filter (MW, LogP, MR, atoms), Veber rule (rotatable bonds, TPSA), Egan rule (LogP, TPSA), and Muegge filter (MW, LogP, TPSA, rings, HBA, HBD, rotatable bonds, carbons). Returns per-rule violation counts, whether each rule passes (0 violations), and an overall assessment. Optionally filter to specific rules. Also returns PAINS/Brenk alerts, bioavailability score, and synthetic accessibility. Useful for filtering compound libraries before purchasing or synthesis.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "enum": ["check_druglikeness"],
          "description": "Operation type"
        },
        "smiles": {
          "type": "string",
          "description": "SMILES string of the molecule to check. Must be a valid small molecule SMILES."
        },
        "rules": {
          "type": ["array", "null"],
          "items": {
            "type": "string",
            "enum": ["lipinski", "ghose", "veber", "egan", "muegge"]
          },
          "description": "Optional list of specific drug-likeness rules to check. If null, all 5 rules are evaluated. Valid values: lipinski, ghose, veber, egan, muegge."
        }
      },
      "required": ["operation", "smiles"]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "smiles": {"type": "string", "description": "Input SMILES"},
        "canonical_smiles": {"type": ["string", "null"], "description": "Canonical SMILES from SwissADME"},
        "molecular_weight": {"type": ["number", "null"]},
        "consensus_logp": {"type": ["number", "null"]},
        "rules": {
          "type": "object",
          "description": "Per-rule assessment results",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "description": {"type": "string"},
              "violations": {"type": ["integer", "null"]},
              "passes": {"type": ["boolean", "null"]}
            }
          }
        },
        "passes_all_rules": {"type": "boolean", "description": "True if molecule passes all checked rules with 0 violations"},
        "bioavailability_score": {"type": ["number", "null"]},
        "pains_alerts": {"type": ["integer", "null"]},
        "brenk_alerts": {"type": ["integer", "null"]},
        "synthetic_accessibility": {"type": ["number", "null"]}
      }
    },
    "test_examples": [
      {
        "operation": "check_druglikeness",
        "smiles": "CC(=O)Oc1ccccc1C(=O)O"
      }
    ]
  }
]
