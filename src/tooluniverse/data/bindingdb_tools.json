          "description": "UniProt accession ID (e.g., P00533 for EGFR)"
        },
        "affinity_cutoff": {
          "type": "integer",
          "description": "Maximum affinity in nM (default: 10000)",
          "default": 10000
        }
      }
    },
    "fields": {
      "operation": "get_ligands_by_uniprot"
    },
    "return_schema": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "query": {"type": "string"},
          "monomerid": {"type": "string"},
          "smile": {"type": "string"},
          "affinity_type": {"type": "string"},
          "affinity": {"type": "string"},
          "pmid": {"type": ["string", "null"]},
          "doi": {"type": ["string", "null"]}
        }
      }
    },
    "test_examples": [
      {"uniprot": "P35354", "affinity_cutoff": 100},
      {"uniprot": "P00742", "affinity_cutoff": 1000}
