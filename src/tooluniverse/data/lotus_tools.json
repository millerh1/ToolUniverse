[
  {
    "name": "LOTUS_search_natural_products",
    "description": "Search the LOTUS (naturaL prOducTs occUrrenceS) database for natural products by name, SMILES, or InChIKey. LOTUS is the largest open natural products database, containing 750,000+ structure-organism pairs from 35,000+ references. Returns compound IDs, structures (SMILES, InChI), molecular properties, and chemical taxonomy classifications. Supports searching by common name (e.g., 'caffeine'), SMILES string, or InChIKey.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query: compound name (e.g., 'caffeine', 'quercetin'), SMILES string, or InChIKey"
        }
      },
      "required": [
        "query"
      ]
    },
    "fields": {
      "endpoint": "https://lotus.naturalproducts.net/api/search/simple?query={query}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "query": "caffeine"
      },
      {
        "query": "quercetin"
      },
      {
        "query": "RYYVLZVUVIJVGH-UHFFFAOYSA-N"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "originalQuery": {
              "type": "string",
              "description": "The query that was searched"
            },
            "determinedInputType": {
              "type": "string",
              "description": "Detected input type: name, SMILES, or InChi Key"
            },
            "naturalProducts": {
              "type": "array",
              "description": "List of matching natural products",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Internal MongoDB ID"
                  },
                  "lotus_id": {
                    "type": "string",
                    "description": "LOTUS identifier (e.g., LTS0075508)"
                  },
                  "wikidata_id": {
                    "type": "string",
                    "description": "Wikidata entity URI"
                  },
                  "traditional_name": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Common name of the compound"
                  },
                  "smiles": {
                    "type": "string",
                    "description": "SMILES structure representation"
                  },
                  "inchi": {
                    "type": "string",
                    "description": "InChI identifier"
                  },
                  "inchikey": {
                    "type": "string",
                    "description": "InChIKey hash"
                  },
                  "molecular_formula": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Molecular formula"
                  },
                  "molecular_weight": {
                    "type": [
                      "number",
                      "null"
                    ],
                    "description": "Molecular weight in g/mol"
                  },
                  "contains_sugar": {
                    "type": "integer",
                    "description": "Whether compound contains sugar moieties (0 or 1)"
                  },
                  "heavy_atom_number": {
                    "type": "integer",
                    "description": "Number of heavy (non-hydrogen) atoms"
                  }
                }
              }
            }
          },
          "description": "LOTUS search results"
        },
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "error"
              ]
            },
            "error": {
              "type": "string"
            }
          },
          "required": [
            "status",
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "LOTUS_get_compound",
    "description": "Get detailed information about a specific natural product from LOTUS by its internal compound ID. Returns comprehensive data including structure (SMILES, InChI), molecular properties (weight, formula, LogP, PSA), drug-likeness metrics (Lipinski violations, H-bond donors/acceptors), chemical taxonomy (NPClassifier and ClassyFire classifications), and source organism data. Use LOTUS_search_natural_products to find the compound ID first.",
    "parameter": {
      "type": "object",
      "properties": {
        "compound_id": {
          "type": "string",
          "description": "LOTUS internal compound ID (MongoDB ObjectId, e.g., '604b8da112e4996162764b83' for caffeine). Obtain from LOTUS_search_natural_products."
        }
      },
      "required": [
        "compound_id"
      ]
    },
    "fields": {
      "endpoint": "https://lotus.naturalproducts.net/api/compound/{compound_id}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "compound_id": "604b8da112e4996162764b83"
      },
      {
        "compound_id": "604b86f112e499616275424f"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "lotus_id": {
              "type": "string",
              "description": "LOTUS identifier"
            },
            "wikidata_id": {
              "type": "string",
              "description": "Wikidata entity URI"
            },
            "traditional_name": {
              "type": [
                "string",
                "null"
              ],
              "description": "Common name"
            },
            "iupac_name": {
              "type": [
                "string",
                "null"
              ],
              "description": "IUPAC systematic name"
            },
            "cas": {
              "type": [
                "string",
                "null"
              ],
              "description": "CAS registry number"
            },
            "smiles": {
              "type": "string",
              "description": "SMILES structure"
            },
            "inchi": {
              "type": "string",
              "description": "InChI identifier"
            },
            "inchikey": {
              "type": "string",
              "description": "InChIKey hash"
            },
            "molecular_formula": {
              "type": [
                "string",
                "null"
              ],
              "description": "Molecular formula"
            },
            "molecular_weight": {
              "type": [
                "number",
                "null"
              ],
              "description": "Molecular weight (g/mol)"
            },
            "xlogp": {
              "type": [
                "number",
                "null"
              ],
              "description": "Predicted XLogP (lipophilicity)"
            },
            "alogp": {
              "type": [
                "number",
                "null"
              ],
              "description": "Predicted ALogP"
            },
            "topoPSA": {
              "type": [
                "number",
                "null"
              ],
              "description": "Topological polar surface area"
            },
            "hBondAcceptorCount": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Number of H-bond acceptors"
            },
            "hBondDonorCount": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Number of H-bond donors"
            },
            "lipinskiRuleOf5Failures": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Number of Lipinski Rule of 5 violations"
            },
            "number_of_rings": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Number of rings"
            },
            "heavy_atom_number": {
              "type": "integer",
              "description": "Number of heavy atoms"
            },
            "contains_sugar": {
              "type": "integer",
              "description": "Contains sugar moiety (0 or 1)"
            },
            "chemicalTaxonomyNPclassifierClass": {
              "type": [
                "string",
                "null"
              ],
              "description": "NPClassifier chemical class"
            },
            "chemicalTaxonomyNPclassifierPathway": {
              "type": [
                "string",
                "null"
              ],
              "description": "NPClassifier biosynthetic pathway"
            },
            "chemicalTaxonomyNPclassifierSuperclass": {
              "type": [
                "string",
                "null"
              ],
              "description": "NPClassifier superclass"
            },
            "chemicalTaxonomyClassyfireKingdom": {
              "type": [
                "string",
                "null"
              ],
              "description": "ClassyFire kingdom"
            },
            "chemicalTaxonomyClassyfireClass": {
              "type": [
                "string",
                "null"
              ],
              "description": "ClassyFire class"
            },
            "chemicalTaxonomyClassyfireDirectParent": {
              "type": [
                "string",
                "null"
              ],
              "description": "ClassyFire direct parent classification"
            },
            "allTaxa": {
              "type": [
                "array",
                "null"
              ],
              "description": "Source organisms from which this natural product has been isolated"
            }
          },
          "description": "Detailed compound information"
        },
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "error"
              ]
            },
            "error": {
              "type": "string"
            }
          },
          "required": [
            "status",
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "LOTUS_search_by_inchikey",
    "description": "Search the LOTUS natural products database specifically by InChIKey, which provides exact structural matching. InChIKey is a 27-character hash that uniquely identifies a chemical structure. This is the most precise way to look up a natural product in LOTUS. Returns the same results as LOTUS_search_natural_products but is optimized for InChIKey lookups.",
    "parameter": {
      "type": "object",
      "properties": {
        "inchikey": {
          "type": "string",
          "description": "InChIKey to search for (e.g., 'RYYVLZVUVIJVGH-UHFFFAOYSA-N' for caffeine, 'IQBMWEYFKNVACH-MEBVLIOMSA-N' for quercetin)"
        }
      },
      "required": [
        "inchikey"
      ]
    },
    "fields": {
      "endpoint": "https://lotus.naturalproducts.net/api/search/simple?query={inchikey}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "inchikey": "RYYVLZVUVIJVGH-UHFFFAOYSA-N"
      },
      {
        "inchikey": "IQBMWEYFKNVACH-MEBVLIOMSA-N"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "originalQuery": {
              "type": "string"
            },
            "determinedInputType": {
              "type": "string",
              "description": "Should be 'InChi Key'"
            },
            "naturalProducts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "lotus_id": {
                    "type": "string"
                  },
                  "traditional_name": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "smiles": {
                    "type": "string"
                  },
                  "inchikey": {
                    "type": "string"
                  },
                  "molecular_formula": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "molecular_weight": {
                    "type": [
                      "number",
                      "null"
                    ]
                  }
                }
              }
            }
          },
          "description": "LOTUS InChIKey search results"
        },
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "error"
              ]
            },
            "error": {
              "type": "string"
            }
          },
          "required": [
            "status",
            "error"
          ]
        }
      ]
    }
  }
]
