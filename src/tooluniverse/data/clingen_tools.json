[
  {
    "name": "ClinGen_search_gene_validity",
    "description": "Search ClinGen gene-disease validity curations by gene symbol. Returns classification (Definitive, Strong, Moderate, Limited, Disputed, Refuted), disease associations, and inheritance patterns. Essential for ACMG variant classification. Example: BRCA1 returns validity scores for hereditary breast/ovarian cancer.",
    "type": "ClinGenTool",
    "parameter": {
      "type": "object",
      "properties": {
        "gene": {
          "type": "string",
          "description": "Gene symbol to search (e.g., BRCA1, TP53, CFTR)"
        }
      },
      "required": ["gene"]
    },
    "fields": {
      "operation": "search_gene_validity",
      "timeout": 60
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "Gene Symbol": {"type": "string"},
              "Gene ID (HGNC)": {"type": "string"},
              "Disease Label": {"type": "string"},
              "Disease ID (MONDO)": {"type": "string"},
              "Classification": {"type": "string"},
              "Inheritance": {"type": "string"},
              "Expert Panel": {"type": "string"}
            }
          }
        },
        "total": {"type": "integer"},
        "gene_searched": {"type": "string"},
        "source": {"type": "string"}
      }
    },
    "test_examples": [
      {"gene": "BRCA1"},
      {"gene": "TP53"}
    ]
  },
